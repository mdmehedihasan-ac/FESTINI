# ── Database ──────────────────────────────────────────────────────────────────
# Neon PostgreSQL connection string
# Es: postgres://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgres://user:password@hostname/dbname?sslmode=require

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Questa viene esposta al frontend con il prefisso VITE_
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── PayPal ────────────────────────────────────────────────────────────────────
PAYPAL_CLIENT_ID=AX...
PAYPAL_CLIENT_SECRET=Ek...
# Questa viene esposta al frontend con il prefisso VITE_
VITE_PAYPAL_CLIENT_ID=AX...
# Usa "sandbox" per test, "live" per produzione
PAYPAL_ENVIRONMENT=sandbox

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
# Il tuo indirizzo Gmail
GMAIL_USER=tuaemail@gmail.com
# App Password Google: https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# A chi arrivano i messaggi di contatto
ADMIN_EMAIL=tuaemail@gmail.com

# ── Admin Panel ───────────────────────────────────────────────────────────────
# Genera con: node -e "require('bcryptjs').hash('TUA_PASSWORD',10).then(console.log)"
ADMIN_PASSWORD_HASH=$2b$10$...
# Stringa casuale lunga almeno 32 caratteri
JWT_SECRET=cambia_questo_con_una_stringa_casuale_sicura_32_chars_min

# ── Sito ──────────────────────────────────────────────────────────────────────
# URL base del sito (senza slash finale). In prod usa l'URL Netlify.
SITE_URL=http://localhost:5173
